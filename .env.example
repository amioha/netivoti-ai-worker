# ================================
# שקיפות ציבורית נתיבות — Worker
# העתק קובץ זה ל-.env ומלא פרטים
# ================================

# Claude / Voyage API Key (אחד לשניהם)
ANTHROPIC_API_KEY=sk-ant-...

# Supabase
SUPABASE_URL=https://xxxx.supabase.co
SUPABASE_KEY=eyJ...

# הגדרות עיבוד
BATCH_SIZE=5           # כמה מסמכים במקביל
CRON_INTERVAL=*/3 * * * *   # כל 3 דקות
MAX_RETRIES=3          # ניסיונות חוזרים לכל מסמך
CHUNK_SIZE=400         # מילים לקטע
CHUNK_OVERLAP=50       # חפיפה בין קטעים
OCR_LANGUAGE=heb+eng   # שפת OCR

# לוגים
LOG_LEVEL=info         # debug / info / warn / error
